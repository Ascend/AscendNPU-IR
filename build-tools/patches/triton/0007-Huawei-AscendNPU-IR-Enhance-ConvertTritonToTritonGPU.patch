From 35dda376df448d7801cf9f8c587d08576232a281 Mon Sep 17 00:00:00 2001
From: Michael LIAO <michael.liao1@huawei.com>
Date: Thu, 14 May 2026 21:22:05 -0400
Subject: [PATCH 7/7] [Huawei][AscendNPU-IR] Enhance ConvertTritonToTritonGPU

- Add `scf.execute_region` conversion
---
 .../TritonToTritonGPU/TritonGPUConversion.cpp |  5 +++
 .../TritonToTritonGPUPass.cpp                 | 32 +++++++++++++++++++
 2 files changed, 37 insertions(+)

diff --git a/lib/Conversion/TritonToTritonGPU/TritonGPUConversion.cpp b/lib/Conversion/TritonToTritonGPU/TritonGPUConversion.cpp
index 97c821ebbd..3b4dd8edf9 100644
--- a/lib/Conversion/TritonToTritonGPU/TritonGPUConversion.cpp
+++ b/lib/Conversion/TritonToTritonGPU/TritonGPUConversion.cpp
@@ -82,8 +82,13 @@ TritonGPUConversionTarget::TritonGPUConversionTarget(
   addLegalDialect<triton::gpu::TritonGPUDialect>();
 
   // Some ops from SCF are illegal
+#if defined(BSPUB_DAVINCI_BISHENGIR)
+  // Exclude `scf.execute_region` from illegal ops.
+  addIllegalOp<scf::ParallelOp, scf::ReduceOp, scf::ReduceReturnOp>();
+#else
   addIllegalOp<scf::ExecuteRegionOp, scf::ParallelOp, scf::ReduceOp,
                scf::ReduceReturnOp>();
+#endif
 
   addDynamicallyLegalDialect<arith::ArithDialect, math::MathDialect,
                              triton::TritonDialect, cf::ControlFlowDialect,
diff --git a/lib/Conversion/TritonToTritonGPU/TritonToTritonGPUPass.cpp b/lib/Conversion/TritonToTritonGPU/TritonToTritonGPUPass.cpp
index 1dc68086aa..1e757609aa 100644
--- a/lib/Conversion/TritonToTritonGPU/TritonToTritonGPUPass.cpp
+++ b/lib/Conversion/TritonToTritonGPU/TritonToTritonGPUPass.cpp
@@ -730,11 +730,43 @@ public:
   }
 };
 
+#if defined(BSPUB_DAVINCI_BISHENGIR)
+struct SCFExecuteRegionPattern
+    : public OpConversionPattern<scf::ExecuteRegionOp> {
+  using OpConversionPattern::OpConversionPattern;
+  // Ref: ConvertForOpTypes
+  LogicalResult
+  matchAndRewrite(scf::ExecuteRegionOp op, OpAdaptor adaptor,
+                  ConversionPatternRewriter &rewriter) const override {
+    auto *converter = getTypeConverter();
+    assert(converter);
+    SmallVector<Type> newResultTypes;
+    if (failed(converter->convertTypes(op.getResultTypes(), newResultTypes)))
+      return failure();
+
+    auto newOp = rewriter.create<scf::ExecuteRegionOp>(
+        op.getLoc(), newResultTypes, adaptor.getOperands());
+    auto &dstRegion = newOp.getRegion();
+    rewriter.inlineRegionBefore(op.getRegion(), dstRegion, dstRegion.end());
+    if (failed(rewriter.convertRegionTypes(&dstRegion, *converter)))
+      return rewriter.notifyMatchFailure(op, "could not convert body types");
+    rewriter.replaceOp(op, newOp.getResults());
+    return success();
+  }
+};
+#endif
+
 void populateSCFPatterns(TritonGPUTypeConverter &typeConverter,
                          RewritePatternSet &patterns) {
   MLIRContext *context = patterns.getContext();
+#if defined(BSPUB_DAVINCI_BISHENGIR)
+  patterns.add<GenericOpPattern<scf::YieldOp>, SCFForPattern, SCFIfPattern,
+               SCFWhilePattern, SCFConditionPattern, SCFExecuteRegionPattern>(
+      typeConverter, context);
+#else
   patterns.add<GenericOpPattern<scf::YieldOp>, SCFForPattern, SCFIfPattern,
                SCFWhilePattern, SCFConditionPattern>(typeConverter, context);
+#endif
 }
 
