+# Transform BiSheng variable name to its corresponding macro definition.
+function(get_bisheng_definitions BS_FEAT_LIST vars)
+  foreach(var IN LISTS vars)
+    string(FIND ${var} "LLVM_BS" index)
+    if ((NOT ${index} EQUAL 0) OR (NOT ${var}))
+      continue()
+    endif()
+    string(REPLACE "LLVM_" "-D" def ${var})
+    list(APPEND def_list ${def})
+  endforeach()
+  set(BS_FEAT_LIST ${def_list} PARENT_SCOPE)
+endfunction()
