+  // when clone users, should ensure the order is the same as before, here record the idx
+  // of every operation in the block.
+  DenseMap<Operation *, unsigned> opIdxInBlock;
+  unsigned idx = 0;
+  for (Operation &op : producer->getBlock()->getOperations()) {
+    opIdxInBlock[&op] = idx++;
