+/// This pattern optimizes a specific "store-to-load" chain where a scalar is
+/// broadcasted, written to a tensor/buffer with a mask, and immediately read
+/// back.
+///
+/// Before:
+/// %scalar = ... : f32
+/// %mask   = vector.constant_mask [1] : vector<1xi1>
+/// %vec    = vector.broadcast %scalar : f32 to vector<1xf32>
+/// %tensor = vector.transfer_write %vec, %base[%c0] {mask = %mask}
+/// %res    = vector.transfer_read %tensor[%c0] : vector<1xf32>
+///
+/// After:
+/// %res    = vector.broadcast %scalar : f32 to vector<1xf32>
+///
+/// Constraints:
+/// 1. The vector size must be 1 (vector<1xf32>).
+/// 2. The transfer_write must have exactly one user (the transfer_read).
+/// 3. The write mask must be a constant_mask of [1].
+/// 4. Read and Write indices must match.
+struct ForwardScalarBroadcast : public OpRewritePattern<TransferReadOp> {
+  using OpRewritePattern<TransferReadOp>::OpRewritePattern;
+
+  LogicalResult matchAndRewrite(TransferReadOp readOp,
+                                PatternRewriter &rewriter) const override {
+    // 1. Match TransferRead of size 1 (e.g., vector<1xf32>)
+    auto readType = dyn_cast<VectorType>(readOp.getType());
+    if (!readType || readType.getNumElements() != 1) {
+      return failure();
+    }
+
+    // 2. Match the source: It must be a TransferWriteOp
+    // In tensor semantics, the 'source' operand of a read is the tensor
+    // produced by the write.
+    Value readSource = readOp.getSource();
+    auto writeOp = readSource.getDefiningOp<TransferWriteOp>();
+    if (!writeOp) {
+      return failure();
+    }
+
+    // 3. Ensure TransferWrite has exactly one user (the TransferRead)
+    if (!writeOp->hasOneUse()) {
+      return failure();
+    }
+
+    // Integrity Check: Ensure Read and Write access the same indices.
+    // If the read is reading from a different offset than the write,
+    // we cannot simply forward the value.
+    if (readOp.getIndices() != writeOp.getIndices()) {
+      return failure();
+    }
+
+    // 4. Match the TransferWrite Mask: Must be vector.constant_mask [1]
+    Value maskValue = writeOp.getMask();
+    if (!maskValue) {
+      return failure(); // Mask is required by the prompt constraints
+    }
+
+    auto maskOp = maskValue.getDefiningOp<ConstantMaskOp>();
+    if (!maskOp) {
+      return failure();
+    }
+
+    // Check that the mask attribute allows exactly 1 element
+    ArrayRef<Attribute> maskDimSizes = maskOp.getMaskDimSizes().getValue();
+    // Assuming 1D vector based on vector<1xf32>, we check the first dimension.
+    if (maskDimSizes.empty())
+      return failure();
+
+    auto dimSizeAttr = dyn_cast<IntegerAttr>(maskDimSizes[0]);
+    if (!dimSizeAttr || dimSizeAttr.getInt() != 1) {
+      return failure();
+    }
+
+    // 5. TransferWrite source must be a BroadcastOp from scalar
+    Value writeSourceVector = writeOp.getVector();
+    if (!isVectorBroadcastFromScalar(writeSourceVector)) {
+      return rewriter.notifyMatchFailure(
+          writeOp, "only optimize if write source is broadcast from scalar");
+    }
+    auto broadcastOp = writeSourceVector.getDefiningOp<BroadcastOp>();
+    if (!broadcastOp) {
+      return failure();
+    }
+
+    Value scalarSource = broadcastOp.getSource();
+    if (isa<VectorType>(scalarSource.getType())) {
+      return failure();
+    }
+
+    // === Rewrite ===
+    // We replace the chain (Read <- Write <- Broadcast <- Scalar)
+    // with (Broadcast <- Scalar).
+    // The new broadcast produces the exact type the read expected.
+    rewriter.replaceOpWithNewOp<BroadcastOp>(readOp, readType, scalarSource);
+
+    return success();
+  }
+};
+
+/// This pattern optimizes a specific "store-to-load" chain where a
+/// transfer_write stores to tensor.empty and transfer_read loads the written
+/// result immediately (read/write vectors can have different shapes).
+///
+/// Before:
+/// %1 = tensor.empty() : tensor<1x64xi1>
+/// %2 = create_mask %c1, %c64 : vector<1x256xi1>
+/// %3 = arith.cmpi ne, ..., ... : vector<1x256xi8>
+/// %4 = transfer_write %3, %1, %10 : vector<1x256xi1>, tensor<1x64xi1>
+/// %5 = transfer_read %4 : tensor<1x64xi1>, vector<1x64xi1>
+/// use(%5)
+///
+/// After:
+/// %1 = arith.cmpi ne, ..., ... : vector<1x256xi8>
+/// %2 = builtin.unrealized_conversion_cast %1
+///      : vector<1x256xi1> to vector<1x64xi1>
+/// use(%2)
+///
+/// Constraints:
+/// 1. Read src must be Write.
+/// 2. Write dst must be tensor empty.
+/// 3. Read and Write Indices/PermutationMap must match.
+struct ForwardWriteEmptyToRead : public OpRewritePattern<TransferReadOp> {
+  using OpRewritePattern<TransferReadOp>::OpRewritePattern;
+
+  LogicalResult matchAndRewrite(TransferReadOp readOp,
+                                PatternRewriter &rewriter) const override {
+    Value src = readOp.getSource();
+    auto writeOp = src.getDefiningOp<vector::TransferWriteOp>();
+    if (!writeOp) {
+      return failure();
+    }
+
+    auto writeDst = writeOp.getSource();
+    auto emptyOp = writeDst.getDefiningOp<tensor::EmptyOp>();
+    if (!emptyOp) {
+      return rewriter.notifyMatchFailure(writeOp,
+                                         "only match write to tensor empty");
+    }
+
+    if (isVectorBroadcastFromScalar(writeOp.getVector())) {
+      // avoid pattern conflict with ForwardScalarBroadcast
+      return rewriter.notifyMatchFailure(writeOp, "not match scalar broadcast");
+    }
+
+    if (readOp.getIndices() != writeOp.getIndices()) {
+      return rewriter.notifyMatchFailure(writeOp,
+                                         "read/write indices mismatch");
+    }
+
+    if (readOp.getPermutationMap() != writeOp.getPermutationMap()) {
+      return rewriter.notifyMatchFailure(writeOp, "permutation map mismatch");
+    }
+
+    Value writtenVector = writeOp.getVector();
+    Type readType = readOp.getVector().getType();
+    if (writtenVector.getType() == readType) {
+      rewriter.replaceOp(readOp, writtenVector);
+    } else {
+      // Create the UnrealizedConversionCast for shape compatibility.
+      // It is undefined behaviour and should be optimized by other passes.
+      auto castOp = rewriter.create<UnrealizedConversionCastOp>(
+          readOp.getLoc(), readType, writtenVector);
+      rewriter.replaceOp(readOp, castOp.getResult(0));
+    }
+
+    return success();
+  }
+};
