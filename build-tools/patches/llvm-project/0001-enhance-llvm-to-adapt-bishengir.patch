+/// Returns true if RaW conflicts caused by loops can be ruled out, specifically
+/// because each loop iteration accesses a disjoint slice of the original
+/// tensor.
+///
+/// Consider the following:
+/// %0 = ... : tensor<?xf32>                                            // DEF
+/// scf.for ... {
+/// "reading_op"(%0) : tensor<?xf32>                                    // READ
+/// %1 = "writing_op"(%0) : tensor<?xf32> -> tensor<?xf32>              // WRITE
+/// ...
+/// }
+///
+/// When the loop is unrolled, we have:
+/// %0 = ... : tensor<?xf32>                                            // DEF
+/// "reading_op"(%0) : tensor<?xf32>                                    // READ
+/// %1 = "writing_op"(%0) : tensor<?xf32> -> tensor<?xf32>              // WRITE
+/// "reading_op"(%0) : tensor<?xf32>                                    // READ
+/// %1 = "writing_op"(%0) : tensor<?xf32> -> tensor<?xf32>              // WRITE
+/// ...
+///
+/// The RaW conflict is possibly present, but consider the following:
+/// %0 = ... : tensor<1024xf32>                                         // DEF
+/// %c64 = arith.constant 64 : index
+/// %c0 = arith.constant 0 : index
+/// %c1024 = arith.constant 1024 : index
+/// scf.for %arg0 = %c0 to %c1024 step %c64 ... {
+/// "reading_op"(%0)[%arg0] [64] : tensor<64xf32>                       // READ
+/// %1 = "writing_op"(%0)[%arg0] [64] :
+/// tensor<64xf32> -> tensor<64xf32>                                    // WRITE
+/// ...
+/// }
+///
+/// Now, the same pattern is present, however notice that in each loop
+/// iteration, we are reading 64 elements, and the offset also increases by 64
+/// in every iteration (it is the induction variable in the loop), so
+/// effectively we have:
+///
+/// %0 = ... : tensor<1024xf32>                                         // DEF
+/// "reading_op"(%0)[0] [64] : tensor<64xf32>                           // READ
+/// %1 = "writing_op"(%0)[0] [64] :
+/// tensor<64xf32> -> tensor<64xf32>                                    // WRITE
+/// "reading_op"(%0)[64] [64] : tensor<64xf32>                          // READ
+/// %1 = "writing_op"(%0)[64] [64] :
+/// tensor<64xf32> -> tensor<64xf32>                                    // WRITE
+/// "reading_op"(%0)[128] [64] : tensor<64xf32>                         // READ
+/// %1 = "writing_op"(%0)[128] [64] :
+/// tensor<64xf32> -> tensor<64xf32>                                    // WRITE
+/// ...
+///
+/// Every read after a write is reading a different part of the tensor, so there
+/// is no RaW. The same logic applies in a multidimensional setting. The below
+/// function checks for this pattern:
+///
+/// 1. The offset in the read/write operation is the loop induction variable, or
+///    a simple affine.apply-derived linear function of it
+/// 2. The effective offset delta between adjacent iterations is larger than or
+///    equal to the number of elements accessed by the read/write
+///
+/// Example:
+///   %off = affine.apply ()[%iv] -> (%iv floordiv 2)
+///   %size0 = affine.min (%iv) -> (-%iv + 92, 64)
+///   %size = affine.apply ()[%size0] -> (%size0 floordiv 2)
+/// With loop step 64, the offset delta is 32 and the size upper bound is 32,
+/// so different iterations still access disjoint slices.
+///
+static bool canUseOpDominanceDueToLoops(OpOperand *uRead, OpOperand *uWrite,
+                                        const SetVector<Value> &definitions,
+                                        AnalysisState &state) {
+  tensor::ExtractSliceOp extract = findCommonExtractSlice(uRead, uWrite);
+  if (!extract) {
+    return false;
+  }
+
+  // Get respective offsets and sizes for the tensor read/write
+  SmallVector<OpFoldResult> offsets = extract.getMixedOffsets();
+  SmallVector<OpFoldResult> sizes = extract.getMixedSizes();
+  if (offsets.size() != sizes.size()) {
+    return false;
+  }
+
+  // find all enclosing loops
+  SmallVector<scf::ForOp> loops;
+  Operation *currScope = uRead->getOwner()->getParentOp();
+  while (currScope) {
+    if (auto loop = dyn_cast<scf::ForOp>(currScope)) {
+      loops.push_back(loop);
+    }
+    currScope = currScope->getParentOp();
+  }
+  DenseSet<scf::ForOp> usedLoops;
+  // check that for each non-constant offset, there exists a loop where the
+  // offset is the induction variable, or a simple affine.apply progression of
+  // it, and the per-iteration offset delta is >= slice size
+  for (auto [offset, size] : llvm::zip(offsets, sizes)) {
+    if (Value offsetVal = offset.dyn_cast<Value>()) {
+      auto progression = matchLoopProgression(offsetVal, loops);
+      if (failed(progression))
+        return false;
+      usedLoops.insert(progression->loop);
+      auto effectStep = getEffectiveStep(*progression);
+      if (!effectStep)
+        return false;
+
+      if (!isEffectStepGreaterThanSlice(*effectStep, {size})) {
+        return false;
+      }
+    }
+  }
+
+  for (auto loop : loops) {
+    if (usedLoops.find(loop) == usedLoops.end()) {
+      return false;
+    }
+  }
+
+  return true;
+}
