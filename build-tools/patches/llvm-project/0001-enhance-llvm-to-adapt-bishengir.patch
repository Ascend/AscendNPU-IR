+  // key is the order idx of users waiting to be cloned, value is user ops.
+  std::map<unsigned, Operation *> usersToBeCloned;
+  for (size_t i = 0; i < producer->getNumResults(); ++i) {
+    Value producerResult = producer->getResult(i);
