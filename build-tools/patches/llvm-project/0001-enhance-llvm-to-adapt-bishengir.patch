+namespace {
+/// Store to load forwarding for transfer operations without permuation maps.
+/// Replace transfer_read + transfer_write by vector.extract + vector.broadcast.
+/// Example:
+/// ```
+/// %11 = arith.maximumf %9, %10 : vector<64xf32>
+/// %12 = vector.transfer_write %11, %arg2[%c0], %0 {in_bounds = [true]} :
+///         vector<64xf32>, tensor<1xf32>
+/// %13 = vector.transfer_read %12[%c0], %cst
+///         {in_bounds = [true, true], permutation_map = #map} :
+///         tensor<1xf32>, vector<1x64xf32>
+/// %14 = arith.subf %5, %13 : vector<1x64xf32>
+/// ```
+/// To:
+/// ```
+/// %10 = arith.maximumf %8, %9 : vector<64xf32>
+/// %11 = vector.extract %10[0] : f32 from vector<64xf32>
+/// %12 = vector.broadcast %11 : f32 to vector<1x64xf32>
+/// %13 = arith.subf %5, %12 : vector<1x64xf32>
+/// ```
+struct TransferReadAfterWriteToExtractAndBroadcast
+    : public OpRewritePattern<TransferReadOp> {
+  using OpRewritePattern::OpRewritePattern;
+
+  LogicalResult matchAndRewrite(TransferReadOp readOp,
+                                PatternRewriter &rewriter) const override {
+    if (readOp.hasOutOfBoundsDim() ||
+        !llvm::isa<RankedTensorType>(readOp.getShapedType()))
+      return failure();
+    auto defWrite = readOp.getSource().getDefiningOp<vector::TransferWriteOp>();
+    if (!defWrite)
+      return failure();
+    if (readOp.getIndices() != defWrite.getIndices())
+      return failure();
+    // check if the vector type of read and write are equal
+    if (defWrite.getVectorType().getNumElements() !=
+        readOp.getVectorType().getNumElements())
+      return failure();
+    // check if the write mask is 1
+    if (auto writeMask = defWrite.getMask()) {
+      if (auto constantMask =
+              writeMask.getDefiningOp<vector::ConstantMaskOp>()) {
+        auto maskDimSizes = constantMask.getMaskDimSizes();
+        if (maskDimSizes.size() != 1 ||
+            mlir::dyn_cast<IntegerAttr>(maskDimSizes[0]).getValue() != 1)
+          return failure();
+      } else {
+        return failure();
+      }
+    } else {
+      return failure();
+    }
+    // do not create ExtractOp + BroadcastOp when type is i1
+    if (defWrite.getVectorType().getElementTypeBitWidth() == 1) {
+      rewriter.replaceOp(readOp, defWrite.getVector());
+      return success();
+    }
+    // create ExtractOp + BroadcastOp to replace readOp
+    Location loc = readOp.getLoc();
+    Value extract =
+        rewriter.create<vector::ExtractOp>(loc, defWrite.getVector(), 0);
+    Value broadcast = rewriter.create<vector::BroadcastOp>(
+        loc, readOp.getVectorType(), extract);
+    rewriter.replaceOp(readOp, broadcast);
+    return success();
+  }
+};
