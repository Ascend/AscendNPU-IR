+
+static void visitUsersRecursively(Value from, int level, Operation *fusedLoop, Block *block,
+                                  DenseMap<Operation *, unsigned> &opIdxInBlock,
+                                  std::map<unsigned, Operation *> &usersToBeCloned) {
+#ifndef NDEBUG
+  const int maxRecursionDepth = 100;
+  assert(level <= maxRecursionDepth && "too many clones!");
+#endif
+  DominanceInfo domInfo;
+  for (OpOperand &userOperand : from.getUses()) {
+    Operation *userOp = userOperand.getOwner();
+    if (!userOp || userOp->hasTrait<OpTrait::IsTerminator>() ||
+        domInfo.properlyDominates(fusedLoop, userOp)) {
+      continue;
+    }
+    while (userOp->getParentOp() != block->getParentOp()) {
+      userOp = userOp->getParentOp();
+    }
+    if (usersToBeCloned.count(opIdxInBlock[userOp])) {
+      continue;
+    }
+    usersToBeCloned[opIdxInBlock[userOp]] = userOp;
+    for (size_t i = 0; i < userOp->getNumResults(); ++i) {
+      visitUsersRecursively(userOp->getResult(i), level + 1, fusedLoop,
+                            block, opIdxInBlock, usersToBeCloned);
+    }
+  }
+}
