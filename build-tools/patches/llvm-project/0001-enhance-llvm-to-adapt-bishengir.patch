+bool isVectorBroadcastFromScalar(Value vector) {
+  auto broadcastOp = vector.getDefiningOp<vector::BroadcastOp>();
+  if (!broadcastOp) {
+    return false;
+  }
+
+  Value src = broadcastOp.getSource();
+  return src.getType().isIntOrIndexOrFloat();
+}
