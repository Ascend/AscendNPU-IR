+
+  // Recursively follow affine.apply chains such as:
+  //   %a = affine.apply ()[%iv] -> (%iv floordiv 2)
+  //   %b = affine.apply ()[%a] -> (%a + 4)
+  //   tensor.extract_slice ... [%b] ...
+  // This is still a progression of the same enclosing loop IV.
+  //
+  // Do not recurse through affine.min here. Unlike sizes, offsets need a
+  // monotone loop progression, and affine.min often produces piecewise values
+  // that should be handled conservatively.
+  if (auto applyOp = getSingleResultAffineApply(operand)) {
+    auto progression = matchLoopProgressionExpr(
+        applyOp.getAffineMap().getResult(0), applyOp.getMapOperands(),
+        applyOp.getAffineMap().getNumDims(), loops);
+    if (succeeded(progression) && (*progression).loop &&
+        (*progression).coefficient > 0 && (*progression).divisor > 0)
+      return progression;
+  }
+
+  return failure();
+}
+
+static FailureOr<LoopProgression>
+combineLoopProgressions(const LoopProgression &lhs,
+                        const LoopProgression &rhs) {
+  if (!lhs.loop)
+    return rhs;
+  if (!rhs.loop)
+    return lhs;
+  if (lhs.loop != rhs.loop || lhs.divisor != rhs.divisor)
+    return failure();
+  return LoopProgression{lhs.loop, lhs.coefficient + rhs.coefficient,
+                         lhs.divisor};
+}
+
+static FailureOr<LoopProgression>
+matchLoopProgressionExpr(AffineExpr expr, ValueRange operands, unsigned numDims,
+                         ArrayRef<scf::ForOp> loops) {
+  if (isa<AffineConstantExpr>(expr))
+    return LoopProgression{};
+
+  if (isa<AffineDimExpr, AffineSymbolExpr>(expr))
+    return matchLoopProgressionOperand(
+        getAffineExprOperand(expr, operands, numDims), loops);
+
+  if (auto binaryExpr = dyn_cast<AffineBinaryOpExpr>(expr)) {
+    if (binaryExpr.getKind() == AffineExprKind::Mul) {
+      auto lhsConst = llvm::dyn_cast<AffineConstantExpr>(binaryExpr.getLHS());
+      auto rhsConst = llvm::dyn_cast<AffineConstantExpr>(binaryExpr.getRHS());
+      if (lhsConst || rhsConst) {
+        auto nested = matchLoopProgressionExpr(lhsConst ? binaryExpr.getRHS()
+                                                        : binaryExpr.getLHS(),
+                                               operands, numDims, loops);
+        if (failed(nested))
+          return failure();
+        (*nested).coefficient *=
+            lhsConst ? lhsConst.getValue() : rhsConst.getValue();
+        return nested;
+      }
+      return failure();
+    }
+
+    if (binaryExpr.getKind() == AffineExprKind::FloorDiv) {
+      auto rhsConst = llvm::dyn_cast<AffineConstantExpr>(binaryExpr.getRHS());
+      if (!rhsConst || rhsConst.getValue() <= 0)
+        return failure();
+      auto nested = matchLoopProgressionExpr(binaryExpr.getLHS(), operands,
+                                             numDims, loops);
+      if (failed(nested))
+        return failure();
+      (*nested).divisor *= rhsConst.getValue();
+      return nested;
+    }
+
+    if (binaryExpr.getKind() == AffineExprKind::Add) {
+      auto lhs = matchLoopProgressionExpr(binaryExpr.getLHS(), operands,
+                                          numDims, loops);
+      auto rhs = matchLoopProgressionExpr(binaryExpr.getRHS(), operands,
+                                          numDims, loops);
+      if (failed(lhs) || failed(rhs))
+        return failure();
+      return combineLoopProgressions(*lhs, *rhs);
+    }
+  }
+
+  return failure();
+}
+
+static affine::AffineApplyOp getSingleResultAffineApply(Value value) {
+  auto applyOp = dyn_cast_or_null<affine::AffineApplyOp>(value.getDefiningOp());
+  if (!applyOp || applyOp.getAffineMap().getNumResults() != 1)
+    return {};
+  return applyOp;
+}
+
+static FailureOr<LoopProgression>
+matchLoopProgression(Value offset, ArrayRef<scf::ForOp> loops) {
+  return matchLoopProgressionOperand(offset, loops);
+}
+
+static std::optional<int64_t> getUpperBoundOfAffineExpr(AffineExpr expr,
+                                                        ValueRange operands,
+                                                        unsigned numDims);
+
+// Example:
+// %sz = affine.apply ()[%n] -> (%n floordiv 2)
+// This tries to derive an upper bound for %sz from the bound of %n.
+static std::optional<int64_t> getUpperBoundOfValue(Value value) {
+  if (auto cst = getConstantIntValue(getAsOpFoldResult(value)))
+    return cst;
+
+  if (auto applyOp = getSingleResultAffineApply(value))
+    return getUpperBoundOfAffineExpr(applyOp.getAffineMap().getResult(0),
+                                     applyOp.getMapOperands(),
+                                     applyOp.getAffineMap().getNumDims());
+
+  if (auto minOp =
+          dyn_cast_or_null<affine::AffineMinOp>(value.getDefiningOp())) {
+    std::optional<int64_t> upperBound;
+    for (AffineExpr expr : minOp.getAffineMap().getResults()) {
+      auto resultBound = getUpperBoundOfAffineExpr(
+          expr, minOp.getMapOperands(), minOp.getAffineMap().getNumDims());
+      if (!resultBound)
+        continue;
+      upperBound =
+          upperBound ? std::min(*upperBound, *resultBound) : resultBound;
+    }
+    return upperBound;
+  }
+
+  return std::nullopt;
+}
+
+static std::optional<int64_t> getEffectiveStep(LoopProgression &progression) {
+  // Only handles static step
+  arith::ConstantOp cstStep =
+      dyn_cast<arith::ConstantOp>(progression.loop.getStep().getDefiningOp());
+  if (!cstStep)
+    return std::nullopt;
+  auto step = cast<IntegerAttr>(cstStep.getValue()).getInt();
+  int64_t scaledStep = step * progression.coefficient;
+  if (scaledStep % progression.divisor != 0)
+    return std::nullopt;
+  int64_t effectiveStep = scaledStep / progression.divisor;
+  return effectiveStep;
+}
+
+static bool isEffectStepGreaterThanSlice(int64_t step,
+                                         OpFoldResult tensorSize) {
+  Value sizeValue = tensorSize.dyn_cast<Value>();
+  if (sizeValue) {
+    // For dynamic size, infer the upper bound
+    if (auto upperBound = getUpperBoundOfValue(sizeValue))
+      return step >= *upperBound;
+  } else if (auto cstSize = getConstantIntValue(tensorSize)) {
+    return step >= *cstSize;
+  }
+  return false;
+}
+
+static std::optional<int64_t> getUpperBoundOfAffineExpr(AffineExpr expr,
+                                                        ValueRange operands,
+                                                        unsigned numDims) {
+  if (auto cst = llvm::dyn_cast<AffineConstantExpr>(expr))
+    return cst.getValue();
+
+  if (isa<AffineDimExpr, AffineSymbolExpr>(expr))
+    return getUpperBoundOfValue(getAffineExprOperand(expr, operands, numDims));
+
+  auto binaryExpr = dyn_cast<AffineBinaryOpExpr>(expr);
+  if (!binaryExpr)
+    return std::nullopt;
+
+  auto lhs = getUpperBoundOfAffineExpr(binaryExpr.getLHS(), operands, numDims);
+  auto rhs = getUpperBoundOfAffineExpr(binaryExpr.getRHS(), operands, numDims);
+
+  switch (binaryExpr.getKind()) {
+  case AffineExprKind::Add:
+    if (lhs && rhs)
+      return *lhs + *rhs;
+    return std::nullopt;
+  case AffineExprKind::Mul: {
+    auto lhsConst = llvm::dyn_cast<AffineConstantExpr>(binaryExpr.getLHS());
+    auto rhsConst = llvm::dyn_cast<AffineConstantExpr>(binaryExpr.getRHS());
+    if (lhsConst && rhs && lhsConst.getValue() >= 0)
+      return lhsConst.getValue() * *rhs;
+    if (rhsConst && lhs && rhsConst.getValue() >= 0)
+      return rhsConst.getValue() * *lhs;
+    return std::nullopt;
+  }
+  case AffineExprKind::FloorDiv: {
+    auto rhsConst = llvm::dyn_cast<AffineConstantExpr>(binaryExpr.getRHS());
+    if (!lhs || !rhsConst || rhsConst.getValue() <= 0)
+      return std::nullopt;
+    return *lhs / rhsConst.getValue();
+  }
+  default:
+    return std::nullopt;
+  }
+}
