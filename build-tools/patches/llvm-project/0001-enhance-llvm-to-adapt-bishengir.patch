+    : ClangBuiltin<"__builtin_cce_simt_red_max_S_fp16x2">,
+      Intrinsic<[], [llvm_ptr_v2f16_ty6, llvm_v2f16_ty, llvm_i32_ty],
+                [IntrArgMemOnly], "", [SDNPMemOperand]>;
+def int_hivm_simt_red_MAX_S_bf16
+    : ClangBuiltin<"__builtin_cce_simt_red_max_S_bf16">,
+      Intrinsic<[], [llvm_ptr_bfloat_ty6, llvm_bfloat_ty, llvm_i32_ty],
+                [IntrArgMemOnly], "", [SDNPMemOperand]>;
+def int_hivm_simt_red_MAX_S_bf16x2
+    : ClangBuiltin<"__builtin_cce_simt_red_max_S_bf16x2">,
+      Intrinsic<[], [llvm_ptr_v2bf16_ty6, llvm_v2bf16_ty, llvm_i32_ty],
+                [IntrArgMemOnly], "", [SDNPMemOperand]>;
+def int_hivm_simt_red_MAX_S_fp32
+    : ClangBuiltin<"__builtin_cce_simt_red_max_S_fp32">,
+      Intrinsic<[], [llvm_ptr_float_ty6, llvm_float_ty, llvm_i32_ty],
+                [IntrArgMemOnly], "", [SDNPMemOperand]>;
+
+foreach mode = ["up", "down", "bfly", "idx"] in {
+  foreach type = ["i32", "i64", "f32", "f16", "v2f16"] in {
+    foreach return_pred = [false, true] in {
+      foreach i = [TPE_SHFL_INFO<mode, type, return_pred>] in {
+        if i.withClangBuiltin then {
+          def i.Name : ClangBuiltin<i.Builtin>,
+                       Intrinsic<i.RetTy, i.ArgsTy,
+                                [IntrInaccessibleMemOnly, IntrConvergent]>;
+        }
+        if i.withoutClangBuiltin then {
+          def i.Name : Intrinsic<i.RetTy, i.ArgsTy,
+                        [IntrInaccessibleMemOnly, IntrConvergent]>;
+        }
+      }
+    }
+  }
+}
+
+foreach op = ["add", "max", "min"] in {
+  foreach type = ["u32", "s32", "f16", "f32"] in {
+    foreach i = [TPE_REDUX_INFO<op, type>] in {
+        def i.Name : ClangBuiltin<i.Builtin>,
+                     Intrinsic<i.RetTy, i.ArgsTy,
+                               [IntrConvergent, IntrInaccessibleMemOnly]>;
+    }
+  }
+}
+
+def int_hivm_sqrt_f : ClangBuiltin<"__builtin_cce_sqrt_f">, Intrinsic<[llvm_float_ty], [llvm_float_ty], [IntrNoMem]>;
+def int_hivm_umulhi : ClangBuiltin<"__builtin_cce_mulhi_ui">, Intrinsic<[llvm_i32_ty], [llvm_i32_ty, llvm_i32_ty], [IntrNoMem]>;
+def int_hivm_log_f : ClangBuiltin<"__builtin_cce_log_f">, Intrinsic<[llvm_float_ty], [llvm_float_ty], [IntrNoMem]>;
