+namespace {
+/// Store to load forwarding for transfer operations without permuation maps.
+/// Replace the transfer_read + transfer_write by vector.shapecast.
+/// Example:
+/// ```
+/// %14 = arith.exp %13 : vector<1x64xf32>
+/// %15 = transfer_write %14, %arg7[%c0, %c0] {in_bounds = [true, true]} :
+///         vector<1x64xf32>, tensor<1x64xf32>
+/// %expanded = expand_shape %15 : tensor<1x64xf32> into tensor<1x4x16xf32>
+/// %16 = transfer_read %expanded[%c0, %c0, %c0], %arg3
+///         {in_bounds = [true, true, true]} : tensor<1x4x16xf32>, vector<1x4x16xf32>
+/// %17 = arith.truncf %16 : vector<1x4x16xf32> to vector<1x4x16xf16>
+/// ```
+/// To:
+/// ```
+/// %14 = arith.exp %13 : vector<1x64xf32>
+/// %15 = vector.shape_cast %14 : vector<1x64xf32> to vector<1x4x16xf32>
+/// %16 = arith.truncf %15 : vector<1x4x16xf32> to vector<1x4x16xf16>
+/// ```
+struct TransferReadAfterWriteAndReshapeToShapecast
+    : public OpRewritePattern<TransferReadOp> {
+  using OpRewritePattern::OpRewritePattern;
+
+  static bool isReassociativeReshapeOp(Operation *op) {
+    if (!op)
+      return false;
+    return isa<tensor::ExpandShapeOp, tensor::CollapseShapeOp>(op);
+  }
+
+  static Operation *getSrcOpOfReassociativeReshapeOp(Operation *op) {
+    if (auto expandShapeOp = dyn_cast<tensor::ExpandShapeOp>(op))
+      return expandShapeOp.getSrc().getDefiningOp();
+    else if (auto collapseShapeOp = dyn_cast<tensor::CollapseShapeOp>(op))
+      return collapseShapeOp.getSrc().getDefiningOp();
+    return nullptr;
+  }
+
+  LogicalResult matchAndRewrite(TransferReadOp readOp,
+                                PatternRewriter &rewriter) const override {
+    if (readOp.hasOutOfBoundsDim() ||
+        !llvm::isa<RankedTensorType>(readOp.getShapedType()))
+      return failure();
+
+    Operation *readSrcOp = readOp.getSource().getDefiningOp();
+    if (!isReassociativeReshapeOp(readSrcOp))
+      return failure();
+    while (isReassociativeReshapeOp(readSrcOp)) {
+      readSrcOp = getSrcOpOfReassociativeReshapeOp(readSrcOp);
+    }
+
+    auto defWrite = dyn_cast_or_null<vector::TransferWriteOp>(readSrcOp);
+    if (!defWrite)
+      return failure();
+
+    if (defWrite.getMask() || readOp.getMask())
+      return failure();
+
+    if (defWrite.getVectorType().getNumElements() !=
+        readOp.getVectorType().getNumElements())
+      return failure();
+
+    // create ShapeCastOp to replace readOp
+    Location loc = readOp.getLoc();
+    auto vec = rewriter.create<vector::ShapeCastOp>(loc, readOp.getVectorType(),
+                                                    defWrite.getVector());
+    rewriter.replaceOp(readOp, vec);
+    return success();
+  }
+};
